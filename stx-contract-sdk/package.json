{
  "name": "@earnwithalee/stx-contract",
  "version": "1.0.0",
  "description": "Premium SDK for interacting with Stacks smart contracts. Features high-level abstractions for Clarity contract calls, data parsing, and transaction monitoring.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run"
  },
  "keywords": [
    "stacks",
    "clarity",
    "stx",
    "blockchain",
    "sdk",
    "bitcoin"
  ],
  "author": "earnwithalee",
  "license": "MIT",
  "devDependencies": {
    "@stacks/network": "^6.0.0",
    "@stacks/transactions": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@stacks/network": "^6.0.0",
    "@stacks/transactions": "^6.0.0"
  }
}
