# Stacks Network Configuration
NEXT_PUBLIC_NETWORK=mainnet
NEXT_PUBLIC_CONTRACT_ADDRESS=SP2PABAF9FTAJYNFZH93XENAJ8FVY99RRM50D2JG9

# Branding
NEXT_PUBLIC_APP_NAME="STX Builder Hub"
NEXT_PUBLIC_APP_ICON="/logo.png"

# Hiro API Configuration
# Get yours from: https://platform.hiro.so/
HIRO_API_KEY=your-hiro-api-key-here

# Analytics & Monitoring
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id-here

# Chainhook Webhook Configuration (Optional)
NEXT_PUBLIC_WEBHOOK_URL=https://your-app.vercel.app/api/chainhook
CHAINHOOK_AUTH_SECRET=your-secret-key-here
CHAINHOOK_UUID=your-chainhook-uuid-here

# Feature Flags
NEXT_PUBLIC_ENABLE_ADMIN_PANEL=false
NEXT_PUBLIC_ENABLE_BETA_TOOLS=true
