  "description": "Comprehensive Stacks smart contract library featuring DeFi, DAOs, and Clarity utility patterns.",
  "scripts": {
    "dev": "cd stx-daily-check-in-hiro && npm run dev",
    "dev:stacksrank": "cd stacksrank && npm run dev",
    "build": "cd stx-daily-check-in-hiro && next build",
    "build:stacksrank": "cd stacksrank && npm run build",
    "start": "cd stx-daily-check-in-hiro && next start",
    "start:stacksrank": "cd stacksrank && npm run start",
    "check": "clarinet check",
    "test": "clarinet test",
    "deploy:testnet": "./scripts/deploy-all.sh",
    "check:all": "./scripts/check-all.sh",
    "lint": "eslint . --ext .js,.ts",
    "format": "prettier --write ."
  },
  "keywords": [
    "stacks",
    "clarity",
    "smart-contracts",
    "blockchain",
    "bitcoin-layers",
    "defi",
    "dao",
    "web3"
  ],
