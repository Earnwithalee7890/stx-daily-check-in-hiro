  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Earnwithalee7890/stacks-contracts.git"
  },
  "bugs": {
    "url": "https://github.com/Earnwithalee7890/stacks-contracts/issues"
  },
  "devDependencies": {
    "@stacks/network": "^6.0.0",
    "@stacks/transactions": "^6.0.0",
    "vitest": "^0.34.0",
    "prettier": "^3.0.0",
    "eslint": "^8.45.0"
  },
  "dependencies": {
    "next": "15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@stacks/connect": "^8.2.6",
    "@stacks/network": "^6.0.0",
